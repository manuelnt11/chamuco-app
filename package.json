{
  "name": "chamuco-app",
  "version": "0.1.0",
  "private": true,
  "description": "Chamuco Travel - Group travel management platform",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manuelnt11/Chamuco-App.git"
  },
  "license": "UNLICENSED",
  "author": "Manuel Nuñez Torres",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "prepare": "husky install",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "db:start": "./scripts/db/start.sh",
    "db:stop": "./scripts/db/stop.sh",
    "db:reset": "./scripts/db/reset.sh",
    "db:logs": "./scripts/db/logs.sh",
    "db:psql": "./scripts/db/psql.sh"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-i18next": "^6.0.3",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.0.10",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.4",
    "turbo": "^1.12.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.1"
}
