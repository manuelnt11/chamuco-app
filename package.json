{
  "name": "chamuco-app",
  "version": "0.1.0",
  "private": true,
  "description": "Chamuco Travel - Group travel management platform",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manuelnt11/Chamuco-App.git"
  },
  "license": "UNLICENSED",
  "author": "Manuel Nuñez Torres",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "validate": "pnpm format:check && pnpm lint && pnpm audit --audit-level=high && pnpm typecheck && pnpm test && pnpm test:coverage",
    "prepare": "husky",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "db:start": "./scripts/db/start.sh",
    "db:stop": "./scripts/db/stop.sh",
    "db:reset": "./scripts/db/reset.sh",
    "db:logs": "./scripts/db/logs.sh",
    "db:psql": "./scripts/db/psql.sh",
    "db:backup": "./scripts/db/backup-prod.sh",
    "db:restore": "./scripts/db/restore-from-prod.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1",
    "turbo": "^2.8.21",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "cross-spawn": ">=6.0.6",
      "glob": ">=10.5.0",
      "lodash": ">=4.18.0",
      "path-to-regexp": ">=8.4.0",
      "picomatch": ">=4.0.4",
      "test-exclude": ">=8.0.0",
      "esbuild@<=0.24.2": ">=0.25.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "file-type@>=13.0.0 <21.3.1": ">=21.3.1",
      "jpeg-js@<0.4.4": ">=0.4.4",
      "jpeg-js@<0.4.0": ">=0.4.0",
      "minimist@<0.2.1": ">=0.2.1",
      "minimist@<0.2.4": ">=0.2.4",
      "tough-cookie@<4.1.3": ">=4.1.3",
      "form-data@<2.5.4": ">=2.5.4",
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "qs@<6.14.1": ">=6.14.1",
      "serialize-javascript@<7.0.5": ">=7.0.5"
    }
  }
}
