# Environment
NODE_ENV=development

# Server
PORT=3001

# API Documentation
SWAGGER_ENABLED=true

# Database
# Local development (Docker Compose) - run `pnpm db:start` first
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chamuco_dev

# Production (Cloud SQL via unix socket from Cloud Run)
# DATABASE_URL=postgresql://chamuco-api-sa@/chamuco_prod?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME

# Local connection to production via Cloud SQL Auth Proxy (debugging only)
# Start proxy: cloud-sql-proxy PROJECT_ID:REGION:INSTANCE_NAME --port=5433
# DATABASE_URL=postgresql://chamuco-api-sa@localhost:5433/chamuco_prod

# Connection pool settings (adjust for production workload)
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
