{
  "extends": [
    "../../.eslintrc.js",
    "next/core-web-vitals",
    "plugin:react/recommended",
    "plugin:react-hooks/recommended",
    "plugin:i18next/recommended"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "plugins": ["react", "react-hooks", "i18next"],
  "rules": {
    "react/react-in-jsx-scope": "off",
    "react/prop-types": "off",
    "@typescript-eslint/explicit-module-boundary-types": "off",
    "i18next/no-literal-string": [
      "error",
      {
        "markupOnly": true,
        "ignoreAttribute": [
          "className",
          "style",
          "type",
          "id",
          "name",
          "data-testid",
          "rel",
          "target",
          "href",
          "src",
          "alt",
          "aria-label",
          "aria-describedby",
          "placeholder"
        ]
      }
    ]
  },
  "settings": {
    "react": {
      "version": "detect"
    }
  },
  "overrides": [
    {
      "files": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "test/**/*",
        "src/app/**/layout.tsx",
        "src/app/**/page.tsx",
        "*.config.ts",
        "*.config.js"
      ],
      "rules": {
        "i18next/no-literal-string": "off"
      }
    }
  ]
}
