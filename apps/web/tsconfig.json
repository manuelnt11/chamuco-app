{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "ignoreDeprecations": "5.0",
    "paths": {
      "@/*": ["./src/*"]
    },
    // Explicit "types" array disables automatic @types/* inclusion.
    // @types/node is not needed here — Next.js provides process.env types via next-env.d.ts.
    "types": ["vitest/globals"],
    "allowJs": true,
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["next-env.d.ts", "src/**/*", "test/**/*", "*.ts", "*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "coverage",
    "vitest.config.ts",
    "playwright.config.ts"
  ]
}
