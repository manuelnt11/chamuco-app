# Firebase Client SDK
# These keys are intentionally public — the NEXT_PUBLIC_ prefix exposes them to the browser.
# Never put the Firebase Admin service account key here.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# API
NEXT_PUBLIC_API_URL=
